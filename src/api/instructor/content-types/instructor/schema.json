{
  "kind": "collectionType",
  "collectionName": "instructors",
  "info": {
    "singularName": "instructor",
    "pluralName": "instructors",
    "displayName": "Instructor"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "title": {
      "type": "string",
      "required": false
    },
    "bio": {
      "type": "richtext"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "credentials": {
      "type": "text",
      "required": false
    },
    "specializations": {
      "type": "string",
      "required": false
    },
    "years_experience": {
      "type": "integer",
      "required": false
    },
    "contact_email": {
      "type": "email",
      "required": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "training_partner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-partner.training-partner",
      "inversedBy": "instructors"
    },
    "training_tracks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::training-track.training-track",
      "mappedBy": "instructor"
    }
  }
}
