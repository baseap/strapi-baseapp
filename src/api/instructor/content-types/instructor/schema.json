{
  "kind": "collectionType",
  "collectionName": "instructors",
  "info": {
    "singularName": "instructor",
    "pluralName": "instructors",
    "displayName": "Instructor"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "label": "Name"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "label": "Slug"
    },
    "title": {
      "type": "string",
      "required": false,
      "label": "Title"
    },
    "bio": {
      "type": "richtext",
      "label": "Bio"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "label": "Avatar"
    },
    "credentials": {
      "type": "text",
      "required": false,
      "label": "Credentials"
    },
    "specializations": {
      "type": "string",
      "required": false,
      "label": "Specializations"
    },
    "years_experience": {
      "type": "integer",
      "required": false,
      "label": "Years Experience"
    },
    "contact_email": {
      "type": "email",
      "required": false,
      "label": "Contact Email"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "label": "Is Active"
    },
    "training_partner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-partner.training-partner",
      "inversedBy": "instructors"
    },
    "training_sessions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training-session.training-session",
      "mappedBy": "instructors"
    }
  }
}