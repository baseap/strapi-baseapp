{
  "kind": "collectionType",
  "collectionName": "premium_categories",
  "info": {
    "singularName": "premium-category",
    "pluralName": "premium-categories",
    "displayName": "Premium Category"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Name"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Slug"
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Description"
    },
    "display_order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Display Order"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Is Active"
    },
    "premium_contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::premium-content.premium-content",
      "mappedBy": "premium_category"
    }
  }
}