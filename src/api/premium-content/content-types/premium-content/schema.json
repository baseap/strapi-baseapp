{
  "kind": "collectionType",
  "collectionName": "premium_contents",
  "info": {
    "singularName": "premium-content",
    "pluralName": "premium-contents",
    "displayName": "Premium Content"
  },
  "options": {
    "draftAndPublish": true,
    "timestamps": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Title"
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Slug"
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Description"
    },
    "content": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Content"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Cover Image"
    },
    "gallery": {
      "type": "component",
      "repeatable": true,
      "component": "shared.media-gallery",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "duration_hours": {
      "type": "decimal",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Duration Hours"
    },
    "max_capacity": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Max Capacity"
    },
    "difficulty_level": {
      "type": "enumeration",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Difficulty Level"
    },
    "age_suitability": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "label": "Age Suitability"
    },
    "language": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Language"
    },
    "location": {
      "type": "component",
      "repeatable": false,
      "component": "shared.location",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "pricing": {
      "type": "component",
      "repeatable": false,
      "component": "shared.pricing",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "what_included": {
      "type": "component",
      "repeatable": true,
      "component": "shared.list-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "what_to_bring": {
      "type": "component",
      "repeatable": true,
      "component": "shared.list-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo_metadata": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Is Featured"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "label": "Is Active"
    },
    "premium_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::premium-category.premium-category",
      "inversedBy": "premium_contents",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "content_creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::content-creator.content-creator",
      "inversedBy": "premium_contents",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "vendor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::vendor.vendor",
      "inversedBy": "premium_contents",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "premium_contents",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}