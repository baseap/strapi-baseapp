{
  "kind": "collectionType",
  "collectionName": "tags",
  "info": {
    "singularName": "tag",
    "pluralName": "tags",
    "displayName": "Tag"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "label": "Name"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "label": "Slug"
    },
    "tag_type": {
      "type": "enumeration",
      "enum": [
        "topic",
        "skill",
        "region",
        "heritage_type"
      ],
      "required": true,
      "label": "Tag Type"
    },
    "description": {
      "type": "text",
      "required": false,
      "label": "Description"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "label": "Is Active"
    },
    "premium_contents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::premium-content.premium-content",
      "mappedBy": "tags"
    },
    "training_tracks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training-track.training-track",
      "mappedBy": "tags"
    }
  }
}