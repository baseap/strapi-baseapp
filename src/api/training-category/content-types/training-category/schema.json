{
  "kind": "collectionType",
  "collectionName": "training_categories",
  "info": {
    "singularName": "training-category",
    "pluralName": "training-categories",
    "displayName": "Training Category"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "what_it_covers": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "research_lineage": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "display_order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "parent_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-category.training-category",
      "inversedBy": "sub_categories",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "sub_categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::training-category.training-category",
      "mappedBy": "parent_category"
    },
    "training_tracks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::training-track.training-track",
      "mappedBy": "training_category"
    }
  }
}
