{
  "kind": "collectionType",
  "collectionName": "training_sessions",
  "info": {
    "singularName": "training-session",
    "pluralName": "training-sessions",
    "displayName": "Training Session"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "order": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "duration_minutes": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "session_type": {
      "type": "enumeration",
      "enum": [
        "lecture",
        "workshop",
        "practice",
        "assessment"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "materials": {
      "type": "component",
      "repeatable": true,
      "component": "shared.attachment",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "video_url": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "training_track": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-track.training-track",
      "inversedBy": "training_sessions",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
