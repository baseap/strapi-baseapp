{
  "kind": "collectionType",
  "collectionName": "training_tracks",
  "info": {
    "singularName": "training-track",
    "pluralName": "training-tracks",
    "displayName": "Training Track"
  },
  "options": {
    "draftAndPublish": true,
    "timestamps": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "overview": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "duration_hours": {
      "type": "decimal",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "difficulty_level": {
      "type": "enumeration",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "learning_objectives": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "max_capacity": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "language": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "location": {
      "type": "component",
      "repeatable": false,
      "component": "shared.location",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "is_virtual": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "pricing": {
      "type": "component",
      "repeatable": false,
      "component": "shared.pricing",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "certificate_available": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo_metadata": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "applicable_launchpad_tracks": {
      "type": "enumeration",
      "enum": [
        "cultural_experience",
        "service",
        "product",
        "health_activity"
      ],
      "multiple": true,
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "recommended_onboarding_stage": {
      "type": "enumeration",
      "enum": [
        "pre_certification",
        "post_certification",
        "tier_progression",
        "anytime"
      ],
      "default": "anytime",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "required_certification_tier": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "strapi_course_id": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "vendor_prep_required": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "training_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-category.training-category",
      "inversedBy": "training_tracks",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "instructor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::instructor.instructor",
      "inversedBy": "training_tracks",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "training_partner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training-partner.training-partner",
      "inversedBy": "training_tracks",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "training_sessions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::training-session.training-session",
      "mappedBy": "training_track"
    },
    "prerequisites": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training-track.training-track",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "vendors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::vendor.vendor",
      "inversedBy": "training_tracks",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "training_tracks",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
