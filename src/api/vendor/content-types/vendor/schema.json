{
  "kind": "collectionType",
  "collectionName": "vendors",
  "info": {
    "singularName": "vendor",
    "pluralName": "vendors",
    "displayName": "Vendor"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "business_name": {
      "type": "string",
      "required": true,
      "label": "Business Name"
    },
    "slug": {
      "type": "uid",
      "targetField": "business_name",
      "label": "Slug"
    },
    "business_type": {
      "type": "enumeration",
      "enum": [
        "individual",
        "cooperative",
        "sme",
        "enterprise"
      ],
      "required": true,
      "label": "Business Type"
    },
    "description": {
      "type": "richtext",
      "label": "Description"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "label": "Logo"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "label": "Cover Image"
    },
    "contact_email": {
      "type": "email",
      "required": false,
      "label": "Contact Email"
    },
    "contact_phone": {
      "type": "string",
      "required": false,
      "label": "Contact Phone"
    },
    "website": {
      "type": "string",
      "required": false,
      "label": "Website"
    },
    "location": {
      "type": "component",
      "repeatable": false,
      "component": "shared.location"
    },
    "verified": {
      "type": "boolean",
      "default": false,
      "label": "Verified"
    },
    "training_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "in_progress",
        "certified"
      ],
      "default": "pending",
      "label": "Training Status"
    },
    "certification_date": {
      "type": "date",
      "required": false,
      "label": "Certification Date"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "label": "Is Active"
    },
    "training_tracks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training-track.training-track",
      "inversedBy": "vendors"
    },
    "premium_contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::premium-content.premium-content",
      "mappedBy": "vendor"
    }
  }
}